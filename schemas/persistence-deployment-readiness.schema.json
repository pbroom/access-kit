{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://access-kit.example/schemas/persistence-deployment-readiness.schema.json",
  "title": "PersistenceDeploymentReadinessReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "checkedAt", "checks", "descriptors", "requiredCapabilities", "manifest", "version"],
  "properties": {
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "checkedAt": { "type": "string", "format": "date-time" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/readinessCheck" }
    },
    "descriptors": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/persistenceBackendDescriptor" }
    },
    "requiredCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph", "audit", "job"],
      "properties": {
        "graph": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/persistenceCapability" }
        },
        "audit": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/persistenceCapability" }
        },
        "job": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/persistenceCapability" }
        }
      }
    },
    "manifest": { "$ref": "#/$defs/persistenceDeploymentManifest" },
    "version": { "type": "string", "const": "persistence-deployment-readiness:v1" }
  },
  "$defs": {
    "readinessCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "component", "status", "message"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-zA-Z0-9_:-]+$" },
        "component": { "type": "string", "enum": ["graph", "audit", "job", "deployment"] },
        "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
        "message": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "persistenceDeploymentManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "generatedAt", "descriptors", "controls", "evidenceRefs", "version"],
      "properties": {
        "environment": { "type": "string", "enum": ["local_proof_point", "production"] },
        "generatedAt": { "type": "string", "format": "date-time" },
        "descriptors": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/persistenceBackendDescriptor" }
        },
        "controls": { "$ref": "#/$defs/persistenceDeploymentControls" },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string", "const": "persistence-deployment-manifest:v1" }
      }
    },
    "persistenceBackendDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "backend", "durable", "immutable", "capabilities", "location", "version"],
      "properties": {
        "component": { "type": "string", "enum": ["graph", "audit", "job"] },
        "backend": {
          "type": "string",
          "enum": ["memory", "local_file", "external_graph", "external_append_only_audit", "external_queue"]
        },
        "durable": { "type": "boolean" },
        "immutable": { "type": "boolean" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/persistenceCapability" }
        },
        "retentionDays": { "type": "integer", "minimum": 1 },
        "location": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "const": "persistence-backend:v1" }
      }
    },
    "persistenceDeploymentControls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identityProviderBackedAccess",
        "operatorAuthorization",
        "secretsExternalized",
        "backupRestoreTested",
        "changeApprovalRequired",
        "monitoringConfigured",
        "migrationPlanReviewed"
      ],
      "properties": {
        "identityProviderBackedAccess": { "type": "boolean" },
        "operatorAuthorization": { "type": "boolean" },
        "secretsExternalized": { "type": "boolean" },
        "backupRestoreTested": { "type": "boolean" },
        "changeApprovalRequired": { "type": "boolean" },
        "monitoringConfigured": { "type": "boolean" },
        "migrationPlanReviewed": { "type": "boolean" }
      }
    },
    "persistenceCapability": {
      "type": "string",
      "enum": [
        "graph_read",
        "graph_write",
        "relationship_query",
        "native_grant_readback",
        "audit_append",
        "audit_hash_chain",
        "audit_immutability",
        "audit_retention",
        "job_enqueue",
        "idempotency_lookup",
        "transactional_writes",
        "backup_restore"
      ]
    }
  }
}
