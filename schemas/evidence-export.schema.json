{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://access-kit.example/schemas/evidence-export.schema.json",
  "title": "EvidenceExport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exportId",
    "framework",
    "controls",
    "periodStart",
    "periodEnd",
    "generatedAt",
    "evidenceTypes",
    "sourceEventIds",
    "responsibleRole",
    "format",
    "auditIntegrity",
    "integrityManifest",
    "controlMappings",
    "artifacts",
    "conmonMetrics",
    "poamItems",
    "poamExport",
    "siemExport",
    "systemBoundary",
    "dataFlows",
    "controlStatements",
    "accessReviews",
    "exceptionRegister",
    "operationalEvidence",
    "oscal",
    "signedPackage",
    "verifierChecks",
    "controlTraceViews"
  ],
  "properties": {
    "exportId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "framework": { "type": "string", "enum": ["nist-800-53", "fedramp-rev5", "custom"] },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" }
    },
    "periodStart": { "type": "string", "format": "date-time" },
    "periodEnd": { "type": "string", "format": "date-time" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "evidenceTypes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sourceEventIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
    },
    "responsibleRole": { "type": "string", "minLength": 1 },
    "format": { "type": "string", "enum": ["json", "zip", "markdown"] },
    "auditIntegrity": { "$ref": "#/$defs/auditIntegrityReport" },
    "integrityManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageHash", "hashAlgorithm", "canonicalization", "generatedAt", "sections", "verifier", "version"],
      "properties": {
        "packageHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "hashAlgorithm": { "type": "string", "const": "sha256" },
        "canonicalization": { "type": "string", "const": "stable-json" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "hash"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
              "itemCount": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "verifier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["documentationPath", "summary", "verificationSteps"],
          "properties": {
            "documentationPath": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 },
            "verificationSteps": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "version": { "type": "string", "const": "evidence-integrity-manifest:v1" }
      }
    },
    "controlMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["controlId", "family", "status", "implementationSummary", "evidenceTypes", "sourceEventIds", "gaps"],
        "properties": {
          "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
          "family": { "type": "string", "minLength": 2 },
          "status": { "type": "string", "enum": ["implemented", "partially_implemented", "planned"] },
          "implementationSummary": { "type": "string", "minLength": 1 },
          "evidenceTypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "sourceEventIds": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
          },
          "gaps": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "description", "format"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": [
              "audit_events",
              "decision_logs",
              "provisioning_logs",
              "drift_findings",
              "control_mapping",
              "siem_export",
              "poam",
              "poam_export",
              "conmon",
              "system_boundary",
              "data_flow",
              "control_statement",
              "access_review",
              "exception_register",
              "security_evidence",
              "oscal_component_definition",
              "oscal_ssp",
              "oscal_assessment_results",
              "signed_evidence_package",
              "control_trace",
              "incident_response",
              "contingency_plan",
              "configuration_baseline"
            ]
          },
          "description": { "type": "string", "minLength": 1 },
          "eventCount": { "type": "integer", "minimum": 0 },
          "format": { "type": "string", "enum": ["json", "zip", "markdown", "jsonl"] }
        }
      }
    },
    "conmonMetrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "unit", "source"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": "number" },
          "unit": { "type": "string", "enum": ["count", "boolean"] },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "poamItems": {
      "type": "array",
      "items": { "$ref": "#/$defs/poamItem" }
    },
    "poamExport": { "$ref": "#/$defs/oscalPoamExport" },
    "siemExport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "eventCount", "schemaVersion", "includesPayloadHashes", "target"],
      "properties": {
        "format": { "type": "string", "const": "jsonl" },
        "eventCount": { "type": "integer", "minimum": 0 },
        "schemaVersion": { "type": "string", "minLength": 1 },
        "includesPayloadHashes": { "type": "boolean" },
        "target": { "type": "string", "enum": ["operator_download", "siem_forwarder"] }
      }
    },
    "systemBoundary": { "$ref": "#/$defs/systemBoundary" },
    "dataFlows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dataFlow" }
    },
    "controlStatements": {
      "type": "array",
      "items": { "$ref": "#/$defs/controlStatement" }
    },
    "accessReviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/accessReview" }
    },
    "exceptionRegister": {
      "type": "array",
      "items": { "$ref": "#/$defs/exceptionRecord" }
    },
    "operationalEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operationalEvidence" }
    },
    "oscal": { "$ref": "#/$defs/oscalEvidenceArtifacts" },
    "signedPackage": { "$ref": "#/$defs/signedPackage" },
    "verifierChecks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/verifierCheck" }
    },
    "controlTraceViews": {
      "type": "array",
      "items": { "$ref": "#/$defs/controlTraceView" }
    },
    "storageReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exportId", "packageHash", "storedAt", "backend", "location", "immutable", "version"],
      "properties": {
        "exportId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "packageHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "storedAt": { "type": "string", "format": "date-time" },
        "backend": { "type": "string", "enum": ["memory", "local_file", "external"] },
        "location": { "type": "string", "minLength": 1 },
        "immutable": { "type": "boolean" },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "poamItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "controlId", "weakness", "status", "ownerRole", "plannedCompletion", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
        "weakness": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "planned", "mitigated"] },
        "ownerRole": { "type": "string", "minLength": 1 },
        "plannedCompletion": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "deploymentScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundaryId", "environment", "liveTenantData", "controls", "periodStart", "periodEnd", "componentIds", "version"],
      "properties": {
        "boundaryId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "environment": { "type": "string", "enum": ["local_proof_point", "production"] },
        "liveTenantData": { "type": "boolean" },
        "controls": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" }
        },
        "periodStart": { "type": "string", "format": "date-time" },
        "periodEnd": { "type": "string", "format": "date-time" },
        "componentIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "version": { "type": "string", "const": "evidence-deployment-scope:v1" }
      }
    },
    "oscalControlImplementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlId", "status", "statement", "responsibleRole", "reviewerRole", "reviewedAt", "sourceEventIds", "sourceArtifactNames", "gaps"],
      "properties": {
        "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
        "status": { "type": "string", "enum": ["implemented", "partially_implemented", "planned"] },
        "statement": { "type": "string", "minLength": 1 },
        "responsibleRole": { "type": "string", "minLength": 1 },
        "reviewerRole": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "sourceEventIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "sourceArtifactNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "oscalPoamExport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uuid", "title", "generatedAt", "items", "sourceControlIds", "version"],
      "properties": {
        "uuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "title": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/poamItem" }
        },
        "sourceControlIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" }
        },
        "version": { "type": "string", "const": "oscal-poam-export:v1" }
      }
    },
    "oscalEvidenceArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["componentDefinition", "systemSecurityPlan", "assessmentResults", "planOfActionAndMilestones", "version"],
      "properties": {
        "componentDefinition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uuid", "title", "framework", "generatedAt", "components", "implementedRequirements", "version"],
          "properties": {
            "uuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "title": { "type": "string", "minLength": 1 },
            "framework": { "type": "string", "enum": ["nist-800-53", "fedramp-rev5", "custom"] },
            "generatedAt": { "type": "string", "format": "date-time" },
            "components": {
              "type": "array",
              "items": { "$ref": "#/$defs/boundaryComponent" }
            },
            "implementedRequirements": {
              "type": "array",
              "items": { "$ref": "#/$defs/oscalControlImplementation" }
            },
            "version": { "type": "string", "const": "oscal-component-definition-fragment:v1" }
          }
        },
        "systemSecurityPlan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uuid", "title", "systemName", "boundaryId", "deploymentScope", "dataFlows", "controlImplementationStatements", "version"],
          "properties": {
            "uuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "title": { "type": "string", "minLength": 1 },
            "systemName": { "type": "string", "minLength": 1 },
            "boundaryId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "deploymentScope": { "$ref": "#/$defs/deploymentScope" },
            "dataFlows": {
              "type": "array",
              "items": { "$ref": "#/$defs/dataFlow" }
            },
            "controlImplementationStatements": {
              "type": "array",
              "items": { "$ref": "#/$defs/oscalControlImplementation" }
            },
            "version": { "type": "string", "const": "oscal-ssp-fragment:v1" }
          }
        },
        "assessmentResults": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uuid", "title", "generatedAt", "reviewedControls", "observations", "version"],
          "properties": {
            "uuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "title": { "type": "string", "minLength": 1 },
            "generatedAt": { "type": "string", "format": "date-time" },
            "reviewedControls": {
              "type": "array",
              "items": { "$ref": "#/$defs/oscalControlImplementation" }
            },
            "observations": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["controlId", "status", "sourceEventIds", "gaps"],
                "properties": {
                  "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
                  "status": { "type": "string", "enum": ["implemented", "partially_implemented", "planned"] },
                  "sourceEventIds": {
                    "type": "array",
                    "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
                  },
                  "gaps": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            "version": { "type": "string", "const": "oscal-assessment-results-fragment:v1" }
          }
        },
        "planOfActionAndMilestones": { "$ref": "#/$defs/oscalPoamExport" },
        "version": { "type": "string", "const": "oscal-evidence-artifacts:v1" }
      }
    },
    "signedPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "packageHash", "hashAlgorithm", "canonicalization", "signatureAlgorithm", "keyId", "signedAt", "signerRole", "signature", "deploymentScope", "sourceEventIds", "reviewedStatementRefs", "controlTraceIds", "version"],
      "properties": {
        "packageId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "packageHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "hashAlgorithm": { "type": "string", "const": "sha256" },
        "canonicalization": { "type": "string", "const": "stable-json" },
        "signatureAlgorithm": { "type": "string", "const": "ed25519-local-proof-signature" },
        "keyId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "signedAt": { "type": "string", "format": "date-time" },
        "signerRole": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "pattern": "^ed25519-local-proof-signature:[A-Za-z0-9_-]+$" },
        "deploymentScope": { "$ref": "#/$defs/deploymentScope" },
        "sourceEventIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "reviewedStatementRefs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "controlTraceIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "version": { "type": "string", "const": "signed-evidence-package:v1" }
      }
    },
    "verifierCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "message"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "message": { "type": "string", "minLength": 1 },
        "expected": { "type": "string", "minLength": 1 },
        "actual": { "type": "string", "minLength": 1 }
      }
    },
    "controlTraceView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId", "controlId", "status", "sourceEventIds", "reviewedStatement", "signatureRef", "deploymentScope", "oscalRefs", "gaps", "version"],
      "properties": {
        "traceId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
        "status": { "type": "string", "enum": ["implemented", "partially_implemented", "planned"] },
        "sourceEventIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "reviewedStatement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reviewerRole", "reviewedAt", "sourceArtifactNames"],
          "properties": {
            "reviewerRole": { "type": "string", "minLength": 1 },
            "reviewedAt": { "type": "string", "format": "date-time" },
            "sourceArtifactNames": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "signatureRef": {
          "type": "object",
          "additionalProperties": false,
          "required": ["packageId", "keyId"],
          "properties": {
            "packageId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "keyId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
          }
        },
        "deploymentScope": { "$ref": "#/$defs/deploymentScope" },
        "oscalRefs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["componentDefinitionUuid", "sspUuid", "assessmentResultsUuid", "poamUuid"],
          "properties": {
            "componentDefinitionUuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "sspUuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "assessmentResultsUuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
            "poamUuid": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
          }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string", "const": "evidence-control-trace-view:v1" }
      }
    },
    "boundaryComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "type", "trustZone", "dataClassification", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["control_plane", "connector", "data_store", "operator", "external_system"] },
        "trustZone": { "type": "string", "enum": ["local_runtime", "synthetic_provider", "operator_boundary", "future_production"] },
        "dataClassification": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "systemBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundaryId", "name", "description", "environment", "liveTenantData", "components", "externalSystems", "assumptions", "version"],
      "properties": {
        "boundaryId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "enum": ["local_proof_point", "production"] },
        "liveTenantData": { "type": "boolean" },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "type", "trustZone", "dataClassification", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["control_plane", "connector", "data_store", "operator", "external_system"] },
              "trustZone": { "type": "string", "enum": ["local_runtime", "synthetic_provider", "operator_boundary", "future_production"] },
              "dataClassification": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "externalSystems": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "dataFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "source", "destination", "dataTypes", "protections", "liveTenantData"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "destination": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "dataTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "protections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "liveTenantData": { "type": "boolean" }
      }
    },
    "controlStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlId", "status", "statement", "responsibleRole", "reviewerRole", "reviewedAt", "evidenceTypes", "sourceArtifactNames", "gaps"],
      "properties": {
        "controlId": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" },
        "status": { "type": "string", "enum": ["implemented", "partially_implemented", "planned"] },
        "statement": { "type": "string", "minLength": 1 },
        "responsibleRole": { "type": "string", "minLength": 1 },
        "reviewerRole": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "evidenceTypes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceArtifactNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "accessReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewId",
        "campaignId",
        "scope",
        "ownerRole",
        "reviewerRole",
        "status",
        "reviewedAt",
        "dueAt",
        "subjectCount",
        "resourceCount",
        "findingCount",
        "exceptionCount",
        "findingIds",
        "exceptionRequestIds",
        "remediationItemIds",
        "ownerApprovals",
        "sourceEventIds",
        "version"
      ],
      "properties": {
        "reviewId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "campaignId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "scope": { "type": "string", "minLength": 1 },
        "ownerRole": { "type": "string", "minLength": 1 },
        "reviewerRole": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["completed", "planned"] },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "dueAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "subjectCount": { "type": "integer", "minimum": 0 },
        "resourceCount": { "type": "integer", "minimum": 0 },
        "findingCount": { "type": "integer", "minimum": 0 },
        "exceptionCount": { "type": "integer", "minimum": 0 },
        "findingIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "exceptionRequestIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "remediationItemIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "ownerApprovals": {
          "type": "array",
          "items": { "$ref": "#/$defs/governanceApproval" }
        },
        "sourceEventIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
        },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "exceptionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "subjectId",
        "resourceId",
        "action",
        "reason",
        "status",
        "requestStatus",
        "requesterRole",
        "ownerRole",
        "approverRole",
        "requestedAt",
        "expiresAt",
        "reviewRequiredAt",
        "ownerApprovals",
        "riskAcceptance",
        "remediation",
        "source",
        "controlIds",
        "evidenceRefs",
        "version"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "subjectId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "resourceId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "action": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["open", "approved", "expired", "revoked", "remediated"] },
        "requestStatus": { "type": "string", "enum": ["requested", "owner_approved", "risk_accepted", "expired", "revoked", "remediated"] },
        "requesterRole": { "type": "string", "minLength": 1 },
        "ownerRole": { "type": "string", "minLength": 1 },
        "approverRole": { "type": "string", "minLength": 1 },
        "requestedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reviewRequiredAt": { "type": "string", "format": "date-time" },
        "ownerApprovals": {
          "type": "array",
          "items": { "$ref": "#/$defs/governanceApproval" }
        },
        "riskAcceptance": { "$ref": "#/$defs/riskAcceptance" },
        "remediation": { "$ref": "#/$defs/remediationTracking" },
        "source": { "type": "string", "enum": ["drift", "access_review", "manual"] },
        "findingId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "sourceFindingId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "controlIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}-[0-9]+(\\([0-9]+\\))?$" }
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "governanceApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approverRole", "decision", "evidenceRefs"],
      "properties": {
        "approverRole": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "decidedAt": { "type": "string", "format": "date-time" },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "riskAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rationale", "residualRisk", "expiresAt", "reviewRequiredAt", "evidenceRefs"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "accepted", "expired", "revoked"] },
        "acceptedByRole": { "type": "string", "minLength": 1 },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "rationale": { "type": "string", "minLength": 1 },
        "residualRisk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reviewRequiredAt": { "type": "string", "format": "date-time" },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "remediationTracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ownerRole", "plan", "dueAt", "evidenceRefs", "poamItemId"],
      "properties": {
        "status": { "type": "string", "enum": ["open", "planned", "in_progress", "completed", "overdue"] },
        "ownerRole": { "type": "string", "minLength": 1 },
        "plan": { "type": "string", "minLength": 1 },
        "dueAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "poamItemId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
      }
    },
    "operationalEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status", "ownerRole", "generatedAt", "summary", "evidenceRefs", "gaps"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "type": {
          "type": "string",
          "enum": ["break_glass", "incident_response", "backup_restore", "contingency", "sbom", "dependency_scan", "vulnerability_scan", "configuration_baseline"]
        },
        "status": { "type": "string", "enum": ["implemented", "planned", "blocked"] },
        "ownerRole": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "minLength": 1 },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "auditIntegrityReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "eventCount", "verifiedAt", "findings", "version"],
      "properties": {
        "status": { "type": "string", "enum": ["verified", "failed"] },
        "eventCount": { "type": "integer", "minimum": 0 },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "firstEventId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "lastEventId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "firstEventHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "lastEventHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message", "severity"],
            "properties": {
              "code": { "type": "string", "minLength": 1 },
              "message": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "eventId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
              "expected": { "type": "string", "minLength": 1 },
              "actual": { "type": "string", "minLength": 1 }
            }
          }
        },
        "auditEventId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
