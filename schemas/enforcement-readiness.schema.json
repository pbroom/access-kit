{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://access-kit.example/schemas/enforcement-readiness.schema.json",
  "title": "EnforcementReadinessReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "connectorId",
    "provider",
    "tenantBoundary",
    "mode",
    "status",
    "checkedAt",
    "control",
    "checks",
    "requiredApproverRole",
    "changeTicketPattern",
    "liveProviderWritesAllowed",
    "auditEventIds",
    "version",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "connectorId": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "tenantBoundary": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "const": "enforcement" },
    "status": { "type": "string", "enum": ["ready", "blocked"] },
    "checkedAt": { "type": "string", "format": "date-time" },
    "control": { "$ref": "#/$defs/enforcementControl" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "message"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
          "message": { "type": "string", "minLength": 1 },
          "evidence": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "requiredApproverRole": { "type": "string", "minLength": 1 },
    "changeTicketPattern": { "type": "string", "minLength": 1 },
    "liveProviderWritesAllowed": { "type": "boolean", "const": false },
    "auditEventIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9_:-]+$" }
    },
    "version": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "enforcementControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["syntheticOnly", "liveProviderWrites", "incidentMode", "breakGlass"],
      "properties": {
        "syntheticOnly": { "type": "boolean" },
        "liveProviderWrites": { "type": "boolean" },
        "incidentMode": { "type": "boolean" },
        "breakGlass": { "type": "boolean" }
      }
    }
  }
}
