{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://access-kit.example/schemas/relationship.schema.json",
  "title": "RelationshipTuple",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "subjectId",
    "relation",
    "objectId",
    "sourceSystem",
    "assertedAt",
    "status",
    "version",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "subjectId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "relation": { "type": "string", "minLength": 1 },
    "objectId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "sourceSystem": { "type": "string", "minLength": 1 },
    "assertedAt": { "type": "string", "format": "date-time" },
    "assertedBy": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["active", "expired", "deleted"] },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    },
    "version": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
