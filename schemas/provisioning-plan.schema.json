{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://access-kit.example/schemas/provisioning-plan.schema.json",
  "title": "ProvisioningPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "connectorId",
    "subjectId",
    "resourceId",
    "action",
    "mode",
    "status",
    "actions",
    "version",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "sourceDecisionId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "connectorId": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "resourceId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
    "action": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["dry_run", "enforcement"] },
    "status": { "type": "string", "enum": ["planned", "approved", "applied", "failed", "rolled_back"] },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actionId",
          "operation",
          "targetPlatform",
          "targetObjectId",
          "requestedState",
          "dryRun",
          "idempotencyKey",
          "status",
          "verification"
        ],
        "properties": {
          "actionId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
          "operation": { "type": "string", "enum": ["grant", "revoke", "expire", "repair", "verify"] },
          "targetPlatform": { "type": "string", "minLength": 1 },
          "targetObjectId": { "type": "string", "pattern": "^[a-z0-9_:-]+$" },
          "requestedState": { "type": "object", "additionalProperties": true },
          "previousState": { "type": "object", "additionalProperties": true },
          "dryRun": { "type": "boolean" },
          "idempotencyKey": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["planned", "skipped", "verified", "failed"] },
          "verification": { "$ref": "#/$defs/provisioningVerification" },
          "compensation": { "$ref": "#/$defs/provisioningCompensation" }
        }
      }
    },
    "version": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "provisioningVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "method", "expectedState"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "verified", "skipped", "failed"] },
        "method": { "type": "string", "minLength": 1 },
        "expectedState": { "type": "object", "additionalProperties": true },
        "readbackState": { "type": "object", "additionalProperties": true },
        "checkedAt": { "type": "string", "format": "date-time" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "provisioningCompensation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "reason", "status", "idempotencyKey"],
      "properties": {
        "operation": { "type": "string", "enum": ["grant", "revoke", "expire", "repair", "verify"] },
        "reason": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["planned", "not_required", "skipped", "failed"] },
        "idempotencyKey": { "type": "string", "minLength": 1 }
      }
    }
  }
}
