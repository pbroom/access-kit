{
  "name": "access-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API-first and CLI-first ReBAC control plane foundation for ATO-ready access governance.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:api": "vitest run tests/api",
    "test:cli": "vitest run tests/cli",
    "test:core": "vitest run tests/core",
    "validate": "pnpm typecheck && pnpm validate:contracts && pnpm validate:ci && pnpm test",
    "validate:contracts": "pnpm validate:schemas && pnpm validate:openapi && pnpm validate:policy && pnpm validate:cli-contract",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "validate:openapi": "tsx scripts/validate-openapi.ts",
    "validate:policy": "tsx scripts/validate-policy-fixtures.ts",
    "validate:cli-contract": "vitest run tests/cli/cli-contract.test.ts",
    "validate:ci": "tsx scripts/validate-ci-workflows.ts",
    "evidence:generate": "tsx scripts/generate-evidence-report.ts",
    "evidence:check": "tsx scripts/generate-evidence-report.ts --check",
    "ci:check": "pnpm validate:contracts && pnpm validate:ci && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm evidence:check",
    "pr:stack": "gt submit --stack"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.4.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.13",
    "yaml": "^2.8.1"
  }
}
