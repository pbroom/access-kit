{
  "name": "access-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API-first and CLI-first ReBAC control plane foundation for ATO-ready access governance.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:api": "vitest run tests/api",
    "test:cli": "vitest run tests/cli",
    "test:core": "vitest run tests/core",
    "test:examples": "vitest run tests/examples",
    "test:postgres": "vitest run tests/core/postgres-persistence.test.ts tests/core/postgres-persistence-unit.test.ts",
    "test:sdk-pep": "vitest run tests/sdk-pep",
    "validate:pep-conformance": "vitest run tests/sdk-pep",
    "validate:sample-admin-app": "vitest run tests/examples/internal-admin-app.test.ts",
    "validate:sample-saas-app": "vitest run tests/examples/sample-saas-app.test.ts",
    "validate": "pnpm typecheck && pnpm validate:contracts && pnpm validate:sample-policy && pnpm validate:docs && pnpm validate:automation && pnpm validate:ci && pnpm validate:deployment-manifests && pnpm validate:persistence-deployment && pnpm validate:runbook-exercises && pnpm validate:secure-sdlc && pnpm validate:live-enforcement-pilot && pnpm validate:pep-conformance && pnpm validate:sample-saas-app && pnpm validate:sample-admin-app && pnpm test",
    "validate:contracts": "pnpm validate:schemas && pnpm validate:openapi && pnpm validate:policy && pnpm validate:connector-security && pnpm validate:cli-contract",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "validate:openapi": "tsx scripts/validate-openapi.ts",
    "validate:policy": "tsx scripts/validate-policy-fixtures.ts",
    "validate:sample-policy": "tsx scripts/validate-sample-policy-repository.ts",
    "generate:policy-tests": "tsx scripts/generate-policy-tests.ts",
    "validate:generated-policy-tests": "tsx scripts/generate-policy-tests.ts --check",
    "validate:connector-security": "node --conditions=types --import tsx scripts/validate-connector-security-gate.ts",
    "validate:cli-contract": "vitest run tests/cli/cli-contract.test.ts",
    "validate:docs": "pnpm validate:docs-lint && tsx scripts/validate-doc-links.ts && pnpm validate:api-reference && pnpm validate:api-collections",
    "validate:docs-lint": "tsx scripts/validate-docs-lint.ts",
    "generate:api-reference": "tsx scripts/generate-api-reference.ts",
    "validate:api-reference": "tsx scripts/generate-api-reference.ts --check",
    "generate:api-collections": "tsx scripts/generate-api-collections.ts",
    "validate:api-collections": "tsx scripts/generate-api-collections.ts --check",
    "api-collections:demo": "tsx examples/api-collections/start-demo-seed-api.ts",
    "validate:automation": "tsx scripts/validate-automation-contracts.ts",
    "validate:ci": "tsx scripts/validate-ci-workflows.ts",
    "validate:deployment-manifests": "tsx scripts/validate-deployment-manifests.ts",
    "validate:persistence-deployment": "tsx scripts/validate-persistence-deployment.ts",
    "validate:runbook-exercises": "tsx scripts/validate-runbook-exercises.ts",
    "validate:secure-sdlc": "tsx scripts/validate-secure-sdlc-evidence.ts",
    "validate:live-enforcement-pilot": "tsx scripts/validate-live-enforcement-pilot.ts",
    "evidence:generate": "tsx scripts/generate-evidence-report.ts",
    "evidence:check": "tsx scripts/generate-evidence-report.ts --check",
    "benchmark:decision-engine": "tsx scripts/generate-decision-engine-benchmark-report.ts",
    "ci:check": "pnpm validate && pnpm lint && pnpm build && pnpm evidence:check",
    "pr:status": "node --import tsx scripts/pr-steward.ts --dry-run",
    "steward:check": "node --import tsx scripts/pr-steward.ts --dry-run",
    "backlog:batch": "node --import tsx scripts/backlog-batch.ts",
    "backlog:next": "node --import tsx scripts/next-slice.ts",
    "quickstart:demo": "tsx scripts/quickstart-demo.ts",
    "evaluation:demo": "tsx scripts/evaluation-demo.ts",
    "playground:policy": "tsx scripts/policy-playground.ts",
    "stack:ready": "node --import tsx scripts/stack-ready.ts",
    "security:pass": "pnpm audit --audit-level high && git diff --check && pnpm ci:check",
    "labels:sync": "node --import tsx scripts/sync-github-labels.ts",
    "labels:check": "node --import tsx scripts/sync-github-labels.ts --check",
    "automation:doctor": "node --import tsx scripts/automation-doctor.ts",
    "pr:stack": "gt submit --stack"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.14": "1.1.16",
      "brace-expansion@5.0.6": "5.0.7",
      "js-yaml@<4.3.0": "^4.3.0",
      "vite": "8.0.16"
    }
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.1",
    "fast-check": "^4.9.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.13",
    "yaml": "^2.8.1"
  }
}
